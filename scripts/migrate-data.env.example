# ─────────────────────────────────────────────────────────────────────────────
# Alinhare — Data Migration Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file to scripts/migrate-data.env
# 2. Fill in every value (the script reads this file automatically)
# 3. NEVER commit the filled-in file — it contains secret service-role keys
# ─────────────────────────────────────────────────────────────────────────────

# OLD project (Lovable / source — read only)
# URL is already known; service role key is in your old Supabase dashboard
# (Settings → API → service_role key)
OLD_SUPABASE_URL=https://cphvgxsododejelswiiy.supabase.co
OLD_SUPABASE_SERVICE_KEY=<old-service-role-key>

# NEW project (destination — write)
# Find both values in your new Supabase project dashboard (Settings → API)
NEW_SUPABASE_URL=https://<new-project-ref>.supabase.co
NEW_SUPABASE_SERVICE_KEY=<new-service-role-key>
